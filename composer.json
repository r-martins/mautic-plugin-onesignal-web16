{
    "name": "r-martins/mautic-plugin-onesignal-web16",
    "description": "OneSignal Web SDK v16: use include_subscription_ids for web, and mark campaign push as failed when OneSignal returns errors or an empty id in JSON (including HTTP 200).",
    "type": "mautic-plugin",
    "license": "GPL-3.0-or-later",
    "keywords": [
        "mautic",
        "mautic-plugin",
        "onesignal",
        "push",
        "web push",
        "subscription"
    ],
    "require": {
        "php": ">=8.2",
        "mautic/core-lib": "^7.0"
    },
    "extra": {
        "install-directory-name": "OnesignalWeb16Bundle"
    },
    "autoload": {
        "psr-4": {
            "MauticPlugin\\OnesignalWeb16Bundle\\": ""
        }
    },
    "config": {
        "sort-packages": true
    }
}
